# ==============================================
#               ENVIRONMENT CONFIG
# ==============================================
# Copy this to .env and fill with actual values
# Remember to add .env to .gitignore!
# ==============================================

# Server Configuration
PORT=8080
NODE_ENV=development
UPLOAD_IMAGE_SIZE_LIMIT_IN_MB=10

# Database
MONGO_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appname>"

# Cloudinary
CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>

# Authentication & Security
# Generate these with: openssl rand -hex 32
JWT_KEY=<generate_32_byte_hex>
CRYPTO_SECRET=<generate_32_byte_hex>
COOKIE_PASSWORD=<generate_32_byte_hex>

# Stripe Payments
STRIPE_PUBLISHABLE_KEY=pk_test_<your_test_key>
STRIPE_SECRET_KEY=sk_test_<your_test_key>
WEBHOOK_SECRET=whsec_<your_webhook_secret>
STRIPE_SUCCESS_URL=http://localhost:3000/listings?success=true
STRIPE_FAILED_URL=http://localhost:3000/listings?success=false

# Twilio (SMS)
TWILIO_ACCOUNT_SID=<your_account_sid>
TWILIO_AUTH_TOKEN=<your_auth_token>
FROM_PHONE_NUMBER=+<your_twilio_phone>

# Mapbox
MAPBOX_API_TOKEN=pk.<your_mapbox_token>

FRONTEND_URL=https://boatbouncer.com


# OAuth Configuration
O_AUTH_SUCCESS_REDIRECT=http://localhost:3000/auth/google/success
O_AUTH_FAILURE_REDIRECT=http://localhost:3000/auth/google/failure

# Google Services
GOOGLE_CONSOLE_KEY=<your_google_console_key>
GOOGLE_CLIENT_ID=<your_client_id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your_client_secret>
GOOGLE_CALLBACK_URL=http://localhost:8080/api/boatbouncer/auth/google/callback

# Facebook Auth
FACEBOOK_APP_ID=<your_app_id>
FACEBOOK_APP_SECRET=<your_app_secret>
FACEBOOK_CALLBACK_URL=http://localhost:8080/api/boatbouncer/auth/facebook/callback

# Admin Credentials
ADMIN_EMAIL=<admin_email@domain.com>
ADMIN_PASSWORD=<strong_admin_password>
COOKIE_NAME=<your_cookie_name>